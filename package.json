{
  "name": "llmmo",
  "private": true,
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"dotnet watch run --project backend\" \"npm run dev --prefix frontend\"",
    "world:setup": "dotnet run --project backend/WorldSetup",
    "harness:plan": "python -m llmmo_harness.cli plan -c harness/config.yaml",
    "harness:execute": "python -m llmmo_harness.cli execute -c harness/config.yaml"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
