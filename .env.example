# Copy to .env and fill in. Do NOT commit .env.
# ---------------------------------------------------------------------------

# --- Database -------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=llmmo

# --- Backend --------------------------------------------------------------
# Long random secret used to sign session JWTs. Keep it stable across restarts
# or all existing sessions are invalidated. Generate e.g. with `openssl rand -base64 48`.
JWT_SECRET=change-me-to-a-long-random-secret

# World tick cadence in seconds.
TICK_INTERVAL_SECONDS=5

# Public URL of the Web UI (the frontend hostname you route in Cloudflare).
# Used for CORS so browsers may send the session cookie to the API.
FRONTEND_PUBLIC_URL=https://app.example.com

# --- Frontend build -------------------------------------------------------
# Public API base URL, baked into the static bundle at build time.
# Must point at the backend hostname you route in Cloudflare, plus /api/v1.
VITE_API_BASE_URL=https://api.example.com/api/v1

# --- Published host ports (your existing Cloudflare tunnel points here) ---
# Pick ports that are FREE on the minipc. 8080 is taken by cadvisor.
FRONTEND_HTTP_PORT=8087
BACKEND_HTTP_PORT=5080

# --- Cloudflare Tunnel ----------------------------------------------------
# Reusing your existing cloudflared container — no token needed here.
# In the Cloudflare dashboard add two Public Hostnames (HOST_IP = minipc LAN IP):
#   app.example.com -> http://HOST_IP:${FRONTEND_HTTP_PORT}
#   api.example.com -> http://HOST_IP:${BACKEND_HTTP_PORT}

# --- Agents (profile: agents) --------------------------------------------
# Create an agent in the Web UI (Agents tab) after seeding, copy its llmmo_ key.
LLMMO_AGENT_KEY=
